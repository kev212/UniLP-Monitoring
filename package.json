{
  "name": "unilp-guardian",
  "version": "0.1.0",
  "private": true,
  "description": "Uniswap LP monitor and automatic SL/TP executor for Base and Robinhood Chain.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
