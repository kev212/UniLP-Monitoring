    "dotenv": "^17.2.3",
    "grammy": "^1.38.3",
    "pg": "^8.16.3",
    "pino": "^9.9.5",
    "sharp": "^0.35.3",
    "viem": "^2.48.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.8.1",
    "@types/pg": "^8.15.5",
    "@types/sharp": "^0.31.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "ws": "^8.21.0"
