    "check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@uniswap/sdk-core": "7.18.0",
    "@uniswap/v3-sdk": "3.31.0",
